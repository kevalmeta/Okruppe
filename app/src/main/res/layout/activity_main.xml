<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:orientation="vertical">

    <Toolbar
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@color/primary_dark">

        <ImageButton
            android:id="@+id/iv_menu_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginLeft="25dp"
            android:src="@drawable/ic_menu_icon"
            android:background="@android:color/transparent"
            android:contentDescription="Menu" />

        <TextView
            android:id="@+id/editTextUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_marginStart="10dp" />
    </Toolbar>

    <LinearLayout
        android:id="@+id/layout_summary_cards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <androidx.cardview.widget.CardView
            android:id="@+id/card_give_amount"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_amount_give"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="20sp"
                    android:textColor="@color/red"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_label_give"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You will give"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_get_amount"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_amount_get"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="20sp"
                    android:textColor="@color/green"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_label_get"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You will get"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <TextView
        android:id="@+id/btn_view_reports_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View Reports"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:drawableLeft="@drawable/ic_pdf"
        android:drawablePadding="8dp"
        android:layout_gravity="center_horizontal"
        android:padding="2dp"
        android:layout_marginBottom="16dp"
        app:drawableTint="@color/white" />

    <RelativeLayout
        android:id="@+id/layout_customer_list_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_white_top_rounded">

        <LinearLayout
            android:id="@+id/layout_search_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/white"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:layout_alignParentTop="true"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view_darshboard"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:queryHint="Search Customer"
                android:iconifiedByDefault="false"
                android:background="@drawable/searchview_background" />

            <LinearLayout
                android:id="@+id/btn_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginStart="8dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_filter_list"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Filter Customers" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filters"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_cashbook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginStart="8dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_cashbook"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Cashbook" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cashbook"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:layout_below="@id/layout_search_report">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_customer_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:clipToPadding="false"
                android:scrollbars="vertical" />

            <Button
                android:id="@+id/btn_add_customer"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="42dp"
                android:backgroundTint="@color/blue"
                android:elevation="6dp"
                android:padding="10dp"
                android:text="+ ADD CUSTOMER"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:cornerRadius="12dp" />
        </FrameLayout>
    </RelativeLayout>

</LinearLayout>